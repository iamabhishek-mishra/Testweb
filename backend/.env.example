# ============================================
#  SUDHA WELLNESS WEBINAR — ENVIRONMENT VARS
#  Copy this file to .env and fill in values
# ============================================

PORT=3000
ADMIN_KEY=your_secret_admin_key_here

# ---- RAZORPAY ----
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ---- PHONEPE ----
# Get from: https://developer.phonepe.com/
PHONEPE_MERCHANT_ID=MERCHANTUAT    # Use your real merchant ID for production
PHONEPE_SALT_KEY=your_salt_key_here
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=TEST                    # Change to PROD for production

# ---- WHATSAPP — OPTION A: TWILIO (easiest to set up) ----
# Sign up at: https://www.twilio.com/whatsapp
# Sandbox number for testing: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- WHATSAPP — OPTION B: META CLOUD API (official business) ----
# Set up at: https://developers.facebook.com/docs/whatsapp/cloud-api
# Leave blank if using Twilio
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# ---- WEBINAR DETAILS ----
ZOOM_MEETING_LINK=https://zoom.us/j/YOUR_MEETING_ID?pwd=YOUR_PASSWORD
ZOOM_MEETING_ID=123 456 7890
ZOOM_MEETING_PASSWORD=wellness
WEBINAR_DATE_STR=Sunday, 20th July 2025 at 6:00 PM IST

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/sudhawellness
# Admin credentials
ADMIN_EMAIL=admin@sudhawellness.com
ADMIN_PASS=admin2025
ADMIN_KEY=admin2025
